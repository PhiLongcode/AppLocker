<Window x:Class="AppLocker.Presentation.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AppLocker.Presentation.ViewModels"
        Title="🔒 AppLocker" Height="560" Width="820"
        Background="{StaticResource PrimaryBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🔒" FontSize="22" VerticalAlignment="Center"/>
                    <TextBlock Text=" AppLocker" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <Border Background="{StaticResource AccentBrush}" CornerRadius="4"
                            Margin="12,0,0,0" Padding="8,2" VerticalAlignment="Center">
                        <TextBlock Text="v1.0 MVP" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>

                <!-- Buttons -->
                <Button Grid.Column="1" Content="⚙ Cài đặt Rule"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,10,0"
                        Command="{Binding OpenSettingsCommand}"/>

                <Button Grid.Column="2" Content="{Binding MonitorButtonText}"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ToggleMonitorCommand}"/>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" Margin="24,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="DANH SÁCH RULE ĐANG CẤU HÌNH"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" FontWeight="SemiBold"
                       Margin="0,0,0,10"/>

            <!-- Rules ListView -->
            <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                    CornerRadius="10" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1">
                <ListView x:Name="RulesList"
                          ItemsSource="{Binding Rules}"
                          SelectedItem="{Binding SelectedRule}"
                          ItemContainerStyle="{StaticResource DarkListViewItem}"
                          Padding="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="📦 Process Name" Width="220"
                                            DisplayMemberBinding="{Binding ProcessName}"/>
                            <GridViewColumn Header="⚙ Rule Type" Width="130"
                                            DisplayMemberBinding="{Binding RuleType}"/>
                            <GridViewColumn Header="⏱ Mô tả" Width="200"
                                            DisplayMemberBinding="{Binding RuleDescription}"/>
                            <GridViewColumn Header="Trạng thái" Width="120"
                                            DisplayMemberBinding="{Binding StatusText}"/>
                        </GridView>
                    </ListView.View>
                    <ListView.Style>
                        <Style TargetType="ListView" BasedOn="{StaticResource DarkListView}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Rules.Count}" Value="0">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate>
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="📋" FontSize="40" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="Chưa có rule nào. Mở Cài đặt để thêm!" 
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               FontSize="13" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                                </StackPanel>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.Style>
                </ListView>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="24,0">
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
