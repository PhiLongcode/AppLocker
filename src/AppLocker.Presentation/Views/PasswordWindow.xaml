<Window x:Class="AppLocker.Presentation.Views.PasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}" Height="280" Width="420"
        MinWidth="360" MinHeight="240"
        Background="{StaticResource PrimaryBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="ToolWindow"
        Topmost="True"
        FontFamily="Segoe UI">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

        <TextBlock Grid.Row="1" Text="{Binding PromptText}" TextWrapping="Wrap"
                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,0,0,16"/>

        <!-- In WPF, PasswordBox cannot be bound securely via regular Binding. For MVP simplicity, we use a TextBox disguised as a password or handle it code-behind. We use TextBox for direct binding here. -->
        <TextBox Grid.Row="2" Text="{Binding PasswordText, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource DarkTextBox}" FontSize="16" Height="36"
                 VerticalContentAlignment="Center" Margin="0,0,0,12"/>

        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}"
                   Foreground="{StaticResource DangerBrush}" FontSize="12" Margin="0,0,0,16"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Content="Hủy" Style="{StaticResource SecondaryButton}" Width="80" Margin="0,0,12,0"
                    Click="CancelButton_Click"/>
            <Button Content="Xác nhận" Style="{StaticResource PrimaryButton}" Width="100"
                    Command="{Binding SubmitCommand}" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
