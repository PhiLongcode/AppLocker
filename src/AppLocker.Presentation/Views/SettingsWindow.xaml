<Window x:Class="AppLocker.Presentation.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:AppLocker.Presentation.Models"
        Title="⚙ Cài đặt Rule" Height="620" Width="720"
        MinWidth="560" MinHeight="480"
        Background="{StaticResource PrimaryBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BtoVConverter"/>
        <DataTemplate x:Key="PresetAppTemplate" DataType="{x:Type models:InstalledAppItem}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" MaxWidth="340" TextTrimming="CharacterEllipsis"
                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="  →  " Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ProcessName}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="⚙ Quản lý Rule" FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20"/>

        <!-- Add Rule Form -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                CornerRadius="10" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="THÊM RULE MỚI"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>

                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding PresetApps}"
                              SelectedItem="{Binding SelectedPreset}"
                              ItemTemplate="{StaticResource PresetAppTemplate}"
                              Style="{StaticResource DarkComboBox}"
                              Margin="0,0,8,0"
                              MaxDropDownHeight="320"
                              ToolTip="Danh sách gợi ý từ phần mềm đã cài (Registry). Chọn để điền tên process bên dưới."/>
                    <Button Grid.Column="1" Content="🔄"
                            Style="{StaticResource SecondaryButton}"
                            Padding="10,6"
                            Command="{Binding ReloadPresetAppsCommand}"
                            ToolTip="Tải lại danh sách từ Windows"/>
                </Grid>

                <TextBlock Grid.Row="2" Text="Tên process (có thể sửa sau khi chọn ở trên)"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10" Margin="0,0,0,6"/>

                <Grid Grid.Row="3" Margin="0,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" Text="{Binding NewProcessName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}"
                                 Margin="0,0,8,0"/>

                        <ComboBox Grid.Column="1" ItemsSource="{Binding RuleTypes}"
                                  SelectedItem="{Binding SelectedRuleType}"
                                  Style="{StaticResource DarkComboBox}"
                                  Margin="0,0,8,0"/>

                        <TextBox Grid.Column="2"
                                 Text="{Binding TimeLimitMinutes, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}"
                                 Margin="0,0,8,0"
                                 Visibility="{Binding IsTimeLimitVisible, Converter={StaticResource BtoVConverter}}"/>

                        <Button Grid.Column="3" Content="+ Thêm"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding AddRuleCommand}"/>
                    </Grid>

                    <TextBlock Grid.Row="1" Text="{Binding StatusMessage}"
                               Foreground="{StaticResource SuccessBrush}"
                               FontSize="12" Margin="0,4,0,0"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Rule List -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                CornerRadius="10" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1">
            <ListView ItemsSource="{Binding Rules}"
                      SelectedItem="{Binding SelectedItem}"
                      Style="{StaticResource DarkListView}"
                      ItemContainerStyle="{StaticResource DarkListViewItem}">
                <ListView.View>
                    <GridView AllowsColumnReorder="True">
                        <GridViewColumn Header="Process" Width="180"
                                        DisplayMemberBinding="{Binding ProcessName}"/>
                        <GridViewColumn Header="Rule Type" Width="110"
                                        DisplayMemberBinding="{Binding RuleType}"/>
                        <GridViewColumn Header="Thời gian (phút)" Width="130"
                                        DisplayMemberBinding="{Binding TimeLimitMinutes}"/>
                        <GridViewColumn Header="Trạng thái" Width="120"
                                        DisplayMemberBinding="{Binding StatusText}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,12">
            <Button Content="🔄 Toggle Enable/Disable"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding ToggleRuleCommand}"
                    Margin="0,0,8,0"/>
            <Button Content="🗑 Xóa"
                    Style="{StaticResource DangerButton}"
                    Command="{Binding RemoveRuleCommand}"/>
        </StackPanel>

        <!-- Save Button -->
        <Button Grid.Row="4" Content="💾 Lưu cấu hình"
                Style="{StaticResource PrimaryButton}"
                Command="{Binding SaveCommand}"
                HorizontalAlignment="Right"
                MinWidth="160"/>
    </Grid>
</Window>
